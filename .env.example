# ── AWS credentials ────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ── S3 storage ─────────────────────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name
S3_PREFIX=v1

# ── Bedrock (QA generation) ────────────────────────────────────────────────────
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# ── Budget guard (pipeline stops if AWS spend exceeds this) ────────────────────
BUDGET_LIMIT_USD=130.0
BUDGET_CHECK_INTERVAL_MINUTES=30

# ── Crawl settings ─────────────────────────────────────────────────────────────
CRAWL_DELAY_SECONDS=1.5
CRAWL_MAX_RETRIES=3
CRAWL_TIMEOUT_SECONDS=30
CRAWL_USER_AGENT=USAImmigrationDatasetBot/1.0 (research; non-commercial)

# ── Text chunking ──────────────────────────────────────────────────────────────
CHUNK_TARGET_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
CHUNK_MAX_TOKENS=1024

# ── HuggingFace ────────────────────────────────────────────────────────────────
HF_TOKEN=hf_your_huggingface_token_here
HF_USERNAME=your_huggingface_username

# ── SageMaker fine-tuning ──────────────────────────────────────────────────────
# Region must support SageMaker JumpStart Llama models (us-west-2 recommended)
SAGEMAKER_REGION=us-west-2
SAGEMAKER_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/SageMakerExecutionRole
SAGEMAKER_BUCKET=your-sagemaker-bucket-name
SAGEMAKER_JOB_NAME=          # set to last job name for poll_and_export.py

# ── QA generation ──────────────────────────────────────────────────────────────
QA_BATCH_SIZE=10
QA_MAX_PAIRS_PER_DOC=50
