# ── Account 1 — crawl + storage ──────────────────────────────────────────────
ACCOUNT1_AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
ACCOUNT1_AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
ACCOUNT1_BEDROCK_API_KEY=your-bedrock-api-key-account1

# ── Account 2 — fine-tuning compute ──────────────────────────────────────────
ACCOUNT2_AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE2
ACCOUNT2_AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY2
ACCOUNT2_BEDROCK_API_KEY=your-bedrock-api-key-account2

# ── Active account selection (pipeline uses these) ────────────────────────────
# Set ACTIVE_ACCOUNT=1 for crawl/storage phase, ACTIVE_ACCOUNT=2 for QA phase
ACTIVE_ACCOUNT=1

# ── Shared config ─────────────────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name
S3_PREFIX=v1
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# ── Budget limits ─────────────────────────────────────────────────────────────
BUDGET_LIMIT_USD=130.0
BUDGET_CHECK_INTERVAL_MINUTES=30
BEDROCK_BUDGET_USD=200.0

# ── Crawl ─────────────────────────────────────────────────────────────────────
CRAWL_DELAY_SECONDS=1.5
CRAWL_MAX_RETRIES=3
CRAWL_TIMEOUT_SECONDS=30
CRAWL_USER_AGENT=USAImmigrationDatasetBot/1.0 (research; non-commercial)

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_TARGET_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
CHUNK_MAX_TOKENS=1024

# ── Hugging Face ──────────────────────────────────────────────────────────────
HF_TOKEN=hf_your_huggingface_token_here
HF_USERNAME=your_huggingface_username

# ── SageMaker fine-tuning ─────────────────────────────────────────────────────
SAGEMAKER_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/service-role/AmazonSageMaker-ExecutionRole-XXXXX
SAGEMAKER_BUCKET=sagemaker-your-bucket-name
SAGEMAKER_REGION=us-east-1

# ── QA generation ─────────────────────────────────────────────────────────────
QA_BATCH_SIZE=10
QA_MAX_PAIRS_PER_DOC=50
